@model IReadOnlyList<ChamedoonWebUI.Controllers.UserEvaluationResult_VM>
@using Chamedoon.Application.Common.Extensions
@using Chamedoon.Application.Services.Immigration
@{
    Layout = "~/Views/Shared/UserPanelLayout.cshtml";
    ViewData["Title"] = "نتایج ارزیابی‌های من";
}

@section UserPanelContent {
    <div class="glass-card dashboard-card">
        <div class="evaluations-header">
            <div>
                <h5>نتایج ارزیابی‌های من</h5>
                <p class="glass-helper mb-0">اینجا می‌توانی آخرین ارزیابی‌های مهاجرتی خودت و سه کشور پیشنهادی هر ارزیابی را ببینی.</p>
            </div>
            <a asp-controller="Immigration" asp-action="Index" class="btn-glass-primary evaluations-new-link">ارزیابی جدید</a>
        </div>

        @if (Model?.Any() == true)
        {
            <div class="evaluation-flashcards" data-evaluation-flashcards>
                <div class="flashcard-counter" aria-live="polite">
                    <span data-flashcard-current>1</span> از <span>@Model.Count</span>
                </div>
                <div class="user-evaluations-list" data-flashcard-stage>
                    @for (var index = 0; index < Model.Count; index++)
                    {
                        var evaluation = Model[index];
                        var shamsiDate = evaluation.CreatedAtUtc.ConvertMiladiToShamsi();
                        <article class="user-evaluation-card @(index == 0 ? "active" : string.Empty)" data-flashcard-card data-card-index="@index" aria-hidden="@(index == 0 ? "false" : "true")">
                        <div class="user-evaluation-summary">
                            <div>
                                <span class="evaluation-date">@(!string.IsNullOrWhiteSpace(shamsiDate) ? shamsiDate : "تاریخ نامشخص")</span>
                                <h6>ارزیابی شماره @evaluation.Id</h6>
                            </div>
                            <div class="evaluation-tags">
                                <span>@evaluation.Input.Age سال</span>
                                <span>@evaluation.Input.JobCategory.ToDisplay()</span>
                                <span>@evaluation.Input.DegreeLevel.ToDisplay()</span>
                            </div>
                        </div>

                        <div class="evaluation-input-summary" aria-label="خلاصه اطلاعات وارد شده">
                            <div class="summary-item">
                                <span>وضعیت تأهل</span>
                                <strong>@evaluation.Input.MaritalStatus.ToDisplay()</strong>
                            </div>
                            <div class="summary-item">
                                <span>شخصیت</span>
                                <strong>@evaluation.Input.MBTIPersonality</strong>
                            </div>
                            <div class="summary-item">
                                <span>عنوان شغلی</span>
                                <strong>@(string.IsNullOrWhiteSpace(evaluation.Input.JobTitle) ? "ثبت نشده" : evaluation.Input.JobTitle)</strong>
                            </div>
                            <div class="summary-item">
                                <span>سابقه کار</span>
                                <strong>@evaluation.Input.WorkExperienceYears سال</strong>
                            </div>
                            <div class="summary-item">
                                <span>رشته تحصیلی</span>
                                <strong>@evaluation.Input.FieldCategory.ToDisplay()</strong>
                            </div>
                            <div class="summary-item">
                                <span>مدرک زبان</span>
                                <strong>@evaluation.Input.LanguageCertificate.ToDisplay()</strong>
                            </div>
                            <div class="summary-item">
                                <span>بودجه سرمایه‌گذاری</span>
                                <strong>@evaluation.Input.InvestmentAmount.ToString("N0")</strong>
                            </div>
                            <div class="summary-item">
                                <span>تمایل به تحصیل</span>
                                <strong>@(evaluation.Input.WillingToStudy ? "دارد" : "ندارد")</strong>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(evaluation.Input.Notes))
                        {
                            <div class="evaluation-note">
                                <span>توضیحات کاربر:</span>
                                <p>@evaluation.Input.Notes</p>
                            </div>
                        }

                        @if (evaluation.TopCountries.Any())
                        {
                            <div class="evaluation-country-grid">
                                @foreach (var country in evaluation.TopCountries)
                                {
                                    var score = Math.Round(country.Score, 0);
                                    <div class="evaluation-country-card">
                                        <span class="country-name">@country.Country.GetDescription()</span>
                                        <span class="country-score">@score%</span>
                                        <span class="country-visa">@country.RecommendedVisaType</span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="detail-value mb-0">برای این ارزیابی نتیجه‌ای ثبت نشده است.</p>
                        }
                        </article>
                    }
                </div>
                <div class="flashcard-actions" aria-label="جابجایی بین ارزیابی‌ها">
                    <button type="button" class="flashcard-button" data-flashcard-prev>قبلی</button>
                    <div class="flashcard-dots" aria-hidden="true">
                        @for (var dotIndex = 0; dotIndex < Model.Count; dotIndex++)
                        {
                            <span class="flashcard-dot @(dotIndex == 0 ? "active" : string.Empty)"></span>
                        }
                    </div>
                    <button type="button" class="flashcard-button flashcard-button-primary" data-flashcard-next>بعدی</button>
                </div>
            </div>
        }
        else
        {
            <div class="empty-evaluations-state">
                <div class="empty-evaluations-icon" aria-hidden="true">🧭</div>
                <h6>هنوز ارزیابی انجام ندادی</h6>
                <p>بعد از انجام ارزیابی مهاجرت، نتیجه‌ها در همین بخش برایت نمایش داده می‌شود.</p>
                <a asp-controller="Immigration" asp-action="Index" class="btn-glass-primary">شروع ارزیابی</a>
            </div>
        }
    </div>
}


@section Scripts {
    <script>
        (() => {
            const root = document.querySelector('[data-evaluation-flashcards]');
            if (!root) {
                return;
            }

            const cards = Array.from(root.querySelectorAll('[data-flashcard-card]'));
            const dots = Array.from(root.querySelectorAll('.flashcard-dot'));
            const currentLabel = root.querySelector('[data-flashcard-current]');
            const prevButton = root.querySelector('[data-flashcard-prev]');
            const nextButton = root.querySelector('[data-flashcard-next]');
            let activeIndex = 0;

            const render = () => {
                cards.forEach((card, index) => {
                    const isActive = index === activeIndex;
                    card.classList.toggle('active', isActive);
                    card.setAttribute('aria-hidden', isActive ? 'false' : 'true');
                });

                dots.forEach((dot, index) => dot.classList.toggle('active', index === activeIndex));

                if (currentLabel) {
                    currentLabel.textContent = (activeIndex + 1).toString();
                }

                if (prevButton) {
                    prevButton.disabled = activeIndex === 0;
                }

                if (nextButton) {
                    nextButton.disabled = activeIndex === cards.length - 1;
                }
            };

            prevButton?.addEventListener('click', () => {
                activeIndex = Math.max(activeIndex - 1, 0);
                render();
            });

            nextButton?.addEventListener('click', () => {
                activeIndex = Math.min(activeIndex + 1, cards.length - 1);
                render();
            });

            render();
        })();
    </script>
}

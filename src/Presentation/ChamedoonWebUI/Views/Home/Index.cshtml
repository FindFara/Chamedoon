@section Styles {
    <link rel="stylesheet" href="~/css/flag-bubbles.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/flag-bubbles.js" asp-append-version="true"></script>
}

<section id="process" class="py-5 bg-white">
    <div class="container">
        <div class="process-flag-stage">
            <div class="flag-bubbles-wrapper flag-bubbles-overlay">
                <div class="flag-bubbles-field" id="flagBubblesField">
                    @foreach (var flag in flagFiles)
                    {
                        var imagePath = Url.Content($"~/images/contries/{flag}");
                        <img class="flag-bubble" src="@imagePath" alt="پرچم @System.IO.Path.GetFileNameWithoutExtension(flag)" loading="lazy" />
                    }
                </div>
            </div>
            <div class="row align-items-center g-5 position-relative">
                <div class="col-lg-5 text-center text-lg-end">
                    <h2 class="fw-bold">یک مسیر شفاف، بخش‌بندی شده و قابل پیگیری.</h2>
                    <p class="text-muted">هر بخش از سفر مهاجرت از کشف تا استقرار با چک‌لیست‌ها و یادآورها پیش روی تو قرار می‌گیرد.</p>
                </div>
                <div class="col-lg-7">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="process-step h-100" data-step="۱">
                            <h5 class="fw-semibold">کشف</h5>
                            <p class="text-muted">با تست تعاملی، پروفایل خودت رو بشناس و پیشنهادهای متناسب دریافت کن.</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="process-step h-100" data-step="۲">
                            <h5 class="fw-semibold">آماده‌سازی</h5>
                            <p class="text-muted">چک‌لیست مدارک و اقدامات لازم رو بر اساس مقصد دلخواهت دنبال کن.</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="process-step h-100" data-step="۳">
                            <h5 class="fw-semibold">اقدام</h5>
                            <p class="text-muted">جدول زمان‌بندی، هزینه‌ها و مدارک رو قبل از ارسال درخواست مرور کن.</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="process-step h-100" data-step="۴">
                            <h5 class="fw-semibold">استقرار</h5>
                            <p class="text-muted">نکات طلایی برای شروع زندگی، کار و تحصیل در مقصد جدیدت رو دریافت کن.</p>
                        </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="insights" class="py-5">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
            <div class="text-end">
                <span class="text-uppercase text-primary fw-semibold">پر بازدیدترین وبلاگ‌ها</span>
            </div>
            <a asp-controller="Blog" asp-action="Index" class="popular-article-more-link">
                <span>بیشتر</span>
            </a>
        </div>
        @{ var fallbackBlogImage = Url.Content("~/img/blog-placeholder.svg"); }
        <div class="row g-4 popular-articles-grid">
            @if (Model.PopularArticles.Any())
            {
                var cardIndex = 0;
                foreach (var article in Model.PopularArticles.Take(4))
                {
                    var visitCountText = article.VisitCount.ToString("N0", CultureInfo.CreateSpecificCulture("fa-IR"));
                    cardIndex++;
                    var stepDelay = (cardIndex * 0.12).ToString("0.##", CultureInfo.InvariantCulture);
                    var shortDescriptionText = Regex.Replace(article.ShortDescription ?? string.Empty, "<.*?>", string.Empty);
                    var imageSrc = string.IsNullOrWhiteSpace(article.ArticleImageName)
                        ? fallbackBlogImage
                        : (article.ArticleImageName!.StartsWith("data:image", System.StringComparison.OrdinalIgnoreCase)
                            || article.ArticleImageName.StartsWith("http", System.StringComparison.OrdinalIgnoreCase))
                            ? article.ArticleImageName
                            : Url.Content($"~/images/blog/{article.ArticleImageName}");
                    <div class="col-md-6 col-xl-3">
                        <article class="popular-article-card h-100" style="--card-delay:@stepDelay">
                            <div class="popular-article-image">
                                <img src="@imageSrc" alt="@article.ArticleTitle" loading="lazy" />
                            </div>
                            <div class="popular-article-body">
                                <h5 class="fw-semibold">@article.ArticleTitle</h5>
                                <p class="text-muted popular-article-description">@shortDescriptionText</p>
                            </div>
                            <div class="popular-article-meta">
                                <span class="popular-article-author" aria-label="@article.Writer">✍️ @article.Writer</span>
                                <span class="popular-article-visit" aria-label="@visitCountText بازدید">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
                                        <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></circle>
                                    </svg>
                                    <span>@visitCountText</span>
                                </span>
                            </div>
                            <a asp-controller="Blog" asp-action="Detail" asp-route-id="@article.Id" class="stretched-link" aria-label="مشاهده مطلب @article.ArticleTitle"></a>
                        </article>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="popular-article-empty">
                        <h5 class="fw-semibold mb-2">فعلاً آماری ثبت نشده است</h5>
                        <p class="mb-0 text-muted">به زودی محبوب‌ترین مقالات براساس بازدید کاربران نمایش داده می‌شود.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section id="testimonials" class="py-5 bg-white">
    <div class="container">
        <div class="row text-center mb-5">
            <div class="col">
                <span class="text-uppercase text-primary fw-semibold">نظرات کاربران</span>
                <h2 class="fw-bold mt-2">کاربرهای چمدون چه می‌گویند؟</h2>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="testimonial-card">
                    <p>«نقشه راه بخش‌بندی شده باعث شد پرونده ویزای دانشجویی‌ام دقیق و به‌موقع پیش بره. هر مرحله که تموم می‌شد، به هدفم نزدیک‌تر می‌شدم.»</p>
                    <h6 class="fw-semibold mb-0">سارا ک.</h6>
                    <small class="text-muted">مهاجرت تحصیلی به هلند</small>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="testimonial-card">
                    <p>«پیشنهادهای وبلاگ همیشه تازه و دقیق بود. تونستم سه مقصد کاری مختلف رو با هم مقایسه کنم و بهترینش رو انتخاب کنم.»</p>
                    <h6 class="fw-semibold mb-0">فرهاد م.</h6>
                    <small class="text-muted">نیروی متخصص در برلین</small>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="testimonial-card">
                    <p>«از آماده‌سازی مدارک تا ماه اول بعد از ورود، اپلیکیشن هر جا لازم بود کنارمون بود و تجربه خانواده‌های دیگه رو در اختیارمون گذاشت.»</p>
                    <h6 class="fw-semibold mb-0">نیلوفر آ.</h6>
                    <small class="text-muted">جابجایی خانوادگی به کلگری</small>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="cta-section text-center text-lg-end">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <h3 class="fw-bold mb-3">آماده‌ای فصل جدید زندگیت رو شروع کنی؟</h3>
                    <p class="mb-0">هزاران نفر با چمدون مسیر مهاجرت‌شون رو مدیریت می‌کنن. اولین بخش شخصی‌سازی شده همین حالا منتظر توست.</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <a asp-controller="Account" asp-action="Register" class="btn-glass-light btn-lg px-4">ساخت حساب کاربری</a>
                </div>
            </div>
        </div>
    </div>
</section>

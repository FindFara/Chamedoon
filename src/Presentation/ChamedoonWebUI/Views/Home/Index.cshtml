<section class="py-4">
    <div class="container">
        <div class="country-marquee-card">
            <div class="country-marquee-row">
                <div class="country-marquee track-right" aria-label="کشورها از چپ به راست">
                    @for (var i = 0; i < 2; i++)
                    {
                        foreach (var country in marqueeRowOne)
                        {
                            <div class="country-chip">
                                <img src="@($"{iconBaseUrl}{country.FlagCode}.svg")" class="country-flag" alt="@country.Name" loading="lazy" />
                                <span class="visually-hidden">@country.Name</span>
                            </div>
                        }
                    }
                </div>
            </div>
            <div class="country-marquee-row">
                <div class="country-marquee track-left" aria-label="کشورها از راست به چپ">
                    @for (var i = 0; i < 2; i++)
                    {
                        foreach (var country in marqueeRowTwo)
                        {
                            <div class="country-chip">
                                <img src="@($"{iconBaseUrl}{country.FlagCode}.svg")" class="country-flag" alt="@country.Name" loading="lazy" />
                                <span class="visually-hidden">@country.Name</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<section id="features" class="py-5">

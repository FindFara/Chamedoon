@model Chamedoon.Application.Services.Immigration.ImmigrationResult
@using Chamedoon.Application.Services.Immigration
@using Chamedoon.Application.Common.Extensions
@using CountryPoints
@using System.Text.RegularExpressions
@using System.Linq
@functions {
    private static string CleanText(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        return Regex.Replace(text, @"\s*【[^】]*】", string.Empty).Trim();
    }
}
@{
    ViewData["Title"] = "نتیجه ارزیابی مهاجرت";
}

@section Styles {
    <link rel="stylesheet" href="~/css/immigration.css" asp-append-version="true" />
}

<section class="immigration-page">
    <div class="container">
        <div class="immigration-result-hero glass-card mb-4">
            <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-lg-between gap-3">
                <div>
                    <h2 class="fw-bold mb-2">مناسب‌ترین گزینه‌ها برای مهاجرت تو</h2>
                    <p class="immigration-helper mb-0">با توجه به اطلاعات وارد شده، این کشورها بیشترین تطابق را با شرایط و تیپ شخصیتی تو دارند. هر کارت شامل مسیر پیشنهادی، امتیاز و نکات کلیدی است.</p>
                </div>
                <div class="immigration-meta">
                    <span class="meta-pill">🎯 مسیرهای برتر</span>
                    <span class="meta-pill">🕒 زمان بررسی کمتر از ۳۰ ثانیه</span>
                </div>
            </div>
            <div class="hero-curve-bridge" aria-hidden="true">
                <svg viewBox="0 0 260 140" role="presentation" focusable="false">
                    <path class="hero-curve-line" d="M12 115 Q132 12 248 68" />
                    <path class="hero-curve-arrow" d="M230 58 L246 72 L225 78" />
                </svg>
            </div>
        </div>

        @if (Model.TopCountries?.Any() == true)
        {
            var topCountries = Model.TopCountries.Take(3).ToList();
            var averageScore = Math.Round(topCountries.Average(c => c.Score), 0);

            <div class="result-insights glass-card mb-4">
                <div class="insights-header">
                    <div>
                        <h4 class="fw-bold mb-1">نمای کلی امتیاز کشورها</h4>
                        <p class="immigration-helper mb-0">درصد تناسب هر کشور و نوع ویزای پیشنهادی :</p>
                    </div>
                    <div class="insight-pill">میانگین کل: @averageScore%</div>
                </div>
                <div class="score-rings" data-score-rings>

                    @for (int i = 0; i < topCountries.Count; i++)
                    {
                        var item = topCountries[i];
                        var score = Math.Round(item.Score, 0);
                        var gradientId = $"ring-grad-{i}";
                        <div class="ring-item" data-score="@score">
                            <div class="ring-visual" role="img" aria-label="@item.Country.GetDescription() با امتیاز @score درصد">
                                <svg class="ring" viewBox="0 0 140 140" aria-hidden="true">
                                    <defs>
                                        <linearGradient id="@gradientId" x1="0%" y1="0%" x2="100%" y2="100%">
                                            <stop offset="0%" stop-color="var(--primary)" stop-opacity="0.95" />
                                            <stop offset="100%" stop-color="var(--primary-soft)" stop-opacity="0.8" />
                                        </linearGradient>
                                    </defs>
                                    <circle class="ring-track" cx="70" cy="70" r="58" />
                                    <circle class="ring-progress" cx="70" cy="70" r="58" stroke="url(#@gradientId)" data-ring-progress />
                                </svg>
                                <div class="ring-center">
                                    <span class="ring-country">@item.Country.GetDescription()</span>
                                </div>
                                <div class="ring-tip" data-ring-tip>
                                    <span class="tip-dot"></span>
                                    <span class="tip-label" data-ring-value>@score%</span>
                                </div>
                            </div>
                            <div class="ring-meta">
                                <span class="visa-pill">@item.RecommendedVisaType</span>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="immigration-result-grid">
                @for (int i = 0; i < topCountries.Count; i++)
                {
                    var item = topCountries[i];
                    var score = Math.Round(item.Score, 0);
                    var livingCosts = item.Data.LivingCosts ?? new MinimumLivingCosts { Housing = new List<HousingCost>() };
                    var languageRequirement = item.Data.LanguageRequirement ?? item.Data.Education?.LanguageRequirement;
                    var panelId = $"country-panel-{i}";
                    <article class="immigration-result-card glass-card" data-country-card>
                        <button class="country-toggle" type="button" data-country-toggle aria-expanded="false" aria-controls="@panelId">
                            <div class="card-header-line">
                                <div class="rank-score">
                                    <div class="rank">#@(@i + 1)</div>
                                </div>
                                <div class="country-heading">
                                    <h4 class="fw-semibold mb-1">@item.Country.GetDescription()</h4>
                                    <div class="mini-meta mb-2">
                                        <span aria-label="@score درصد امتیاز">🔥 @score%</span>
                                        <span aria-label="ویزای پیشنهادی">🎟️ @item.RecommendedVisaType</span>
                                    </div>
                                </div>
                            </div>
                            <div class="country-summary">
                                <span class="summary-label">مشاهده جزئیات</span>
                                <span class="toggle-icon" aria-hidden="true"></span>
                            </div>
                        </button>

                        <div class="country-panel" id="@panelId" data-country-panel hidden>
                            <div class="detail-grid">
                                @{
                                    var jobDetailId = $"detail-job-{i}";
                                }
                                <div class="detail-block">
                                    <button class="detail-toggle" type="button" data-detail-toggle aria-expanded="false" aria-controls="@jobDetailId">
                                        <span class="detail-title">شغل وارد شده</span>
                                        <span class="toggle-icon" aria-hidden="true"></span>
                                    </button>
                                    <div class="detail-body" id="@jobDetailId" data-detail-body hidden>
                                        @if (item.Data.Job is { } job)
                                        {
                                            <p class="mb-1"><strong>@(string.IsNullOrWhiteSpace(job.EnteredTitle) ? job.Job.GetDescription() : job.EnteredTitle)</strong> – @job.Job.GetDescription()</p>
                                            <p class="detail-text mb-1">@CleanText(job.Description)</p>
                                            <p class="detail-tag mb-0">@CleanText(job.ExperienceImpact)</p>
                                        }
                                        else
                                        {
                                            <p class="detail-text mb-0">برای این کشور تطابق مستقیمی با عنوان شغلی پیدا نشد.</p>
                                        }
                                    </div>
                                </div>

                                @{
                                    var educationDetailId = $"detail-education-{i}";
                                }
                                <div class="detail-block">
                                    <button class="detail-toggle" type="button" data-detail-toggle aria-expanded="false" aria-controls="@educationDetailId">
                                        <span class="detail-title">رشته و تحصیل</span>
                                        <span class="toggle-icon" aria-hidden="true"></span>
                                    </button>
                                    <div class="detail-body" id="@educationDetailId" data-detail-body hidden>
                                        @if (item.Data.Education is { } education)
                                        {
                                            <p class="mb-1"><strong>@education.Field.GetDescription()</strong> (@education.DegreeLevel.GetDescription())</p>
                                            <p class="detail-text mb-1">@CleanText(education.Description)</p>
                                            <p class="detail-tag mb-0">نیازمندی زبان: @CleanText(education.LanguageRequirement)</p>
                                        }
                                        else
                                        {
                                            <p class="detail-text mb-0">اطلاعات دقیق رشته متناسب در دیتاست این کشور ثبت نشده است.</p>
                                        }
                                    </div>
                                </div>

                                @{
                                    var languageDetailId = $"detail-language-{i}";
                                }
                                <div class="detail-block">
                                    <button class="detail-toggle" type="button" data-detail-toggle aria-expanded="false" aria-controls="@languageDetailId">
                                        <span class="detail-title">اطلاعات تکمیلی و زبان</span>
                                        <span class="toggle-icon" aria-hidden="true"></span>
                                    </button>
                                    <div class="detail-body" id="@languageDetailId" data-detail-body hidden>
                                        <p class="detail-text mb-1">@CleanText(item.Data.AdditionalInfo)</p>
                                        @if (!string.IsNullOrWhiteSpace(languageRequirement))
                                        {
                                            <p class="detail-tag mb-0">@CleanText(languageRequirement)</p>
                                        }
                                    </div>
                                </div>

                                @{
                                    var investmentDetailId = $"detail-investment-{i}";
                                }
                                <div class="detail-block">
                                    <button class="detail-toggle" type="button" data-detail-toggle aria-expanded="false" aria-controls="@investmentDetailId">
                                        <span class="detail-title">هزینه و سرمایه‌گذاری</span>
                                        <span class="toggle-icon" aria-hidden="true"></span>
                                    </button>
                                    <div class="detail-body" id="@investmentDetailId" data-detail-body hidden>
                                        <p class="detail-text mb-1">@CleanText(item.Data.InvestmentNotes)</p>
                                        @{
                                            var investmentLabel = item.Data.InvestmentAmount > 0
                                                ? $"{item.Data.InvestmentAmount:N0} {item.Data.InvestmentCurrency}".Trim()
                                                : (!string.IsNullOrWhiteSpace(item.Data.InvestmentCurrency)
                                                    ? $"نامشخص ({item.Data.InvestmentCurrency})"
                                                    : "نامشخص");
                                        }
                                        <div class="detail-tag mb-0">حداقل سرمایه: @investmentLabel</div>
                                    </div>
                                </div>

                                @{
                                    var livingDetailId = $"detail-living-{i}";
                                }
                                <div class="detail-block">
                                    <button class="detail-toggle" type="button" data-detail-toggle aria-expanded="false" aria-controls="@livingDetailId">
                                        <span class="detail-title">هزینه‌های زندگی</span>
                                        <span class="toggle-icon" aria-hidden="true"></span>
                                    </button>
                                    <div class="detail-body" id="@livingDetailId" data-detail-body hidden>
                                        @{
                                            var livingItems = new List<(string Label, string? Value)>
                                            {
                                                ("متوسط هزینه‌های ماهانه برای یک خانواده چهار نفره (بدون اجاره)", livingCosts.FamilyMonthly),
                                                ("میانگین هزینه زندگی برای یک نفر (بدون اجاره)", livingCosts.SingleMonthly),
                                                ("حمل و نقل", livingCosts.Transport),
                                                ("خدمات رفاهی", livingCosts.Utilities),
                                                ("آپارتمان یک خوابه", livingCosts.RentOneBedroom),
                                                ("آپارتمان سه خوابه", livingCosts.RentThreeBedroom),
                                            }
                                            .Where(item => !string.IsNullOrWhiteSpace(item.Value))
                                            .ToList();
                                        }

                                        @if (livingItems.Any())
                                        {
                                            <div class="living-grid">
                                                @foreach (var entry in livingItems)
                                                {
                                                    <div class="living-item">
                                                        <div class="living-label">@entry.Label</div>
                                                        <div class="living-value">@CleanText(entry.Value)</div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <p class="detail-text mb-0">اطلاعات هزینه‌های زندگی برای این کشور ثبت نشده است.</p>
                                        }
                                    </div>
                                </div>

                                @{
                                    var restrictionDetailId = $"detail-restrictions-{i}";
                                }
                                <div class="detail-block">
                                    <button class="detail-toggle" type="button" data-detail-toggle aria-expanded="false" aria-controls="@restrictionDetailId">
                                        <span class="detail-title">وضعیت تاهل و محدودیت‌ها</span>
                                        <span class="toggle-icon" aria-hidden="true"></span>
                                    </button>
                                    <div class="detail-body" id="@restrictionDetailId" data-detail-body hidden>
                                        <p class="detail-text mb-1">@CleanText(item.Data.MaritalStatusImpact)</p>
                                        @if (item.Data.IranianMigrationRestrictions?.Any() == true)
                                        {
                                            <ul class="restriction-list mb-0">
                                                @foreach (var note in item.Data.IranianMigrationRestrictions)
                                                {
                                                    <li>@CleanText(note)</li>
                                                }
                                            </ul>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="immigration-empty">
                <h5 class="fw-semibold mb-2">اطلاعات کافی برای پیشنهاد وجود ندارد</h5>
                <p class="immigration-helper mb-0">لطفاً فرم ارزیابی را با دقت بیشتری تکمیل کن یا فیلدهای اختیاری را هم پر کن تا پیشنهاد دقیق‌تری ارائه دهیم.</p>
            </div>
        }

        <div class="immigration-actions mt-4">
            <a asp-controller="Immigration" asp-action="Index" class="btn-outline-glass">ویرایش اطلاعات و ارزیابی مجدد</a>
            <a asp-controller="Blog" asp-action="Index" class="btn-glass-primary">مطالعه نکات کاربردی مهاجرت</a>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/immigration.js" asp-append-version="true"></script>
}
